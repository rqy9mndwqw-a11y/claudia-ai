# Groq API key (server-side only, never exposed to client)
GROQ_API_KEY=gsk_your_key_here

# Session token signing secret (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET=your_session_secret_here_min_32_chars

# CLAUDIA token contract on Base
NEXT_PUBLIC_CLAUDIA_CONTRACT=0x98eBd4Ac5d4f7022140c51e03CAc39d9F94CDE9B

# Minimum $CLAUDIA balance for basic access (matches GATE_THRESHOLDS.dashboard)
NEXT_PUBLIC_MIN_CLAUDIA_BALANCE=1000000

# WalletConnect / Reown project ID (required — get one free at cloud.reown.com)
# App will not connect wallets without a valid project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_reown_project_id_here

# Optional: Base RPC URL (defaults to https://mainnet.base.org)
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Approved creator wallet addresses (comma-separated, lowercase)
# Only these wallets can create agents. Others see "Coming Soon".
NEXT_PUBLIC_APPROVED_CREATORS=0xYOUR_WALLET_ADDRESS

# taapi.io API key (server-side only — market data for agent context)
taapi_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJjbHVlIjoiNjljOWM2NzdlZTAzMzMxMWE0YTEyOGE5IiwiaWF0IjoxNzc0ODMxMzQ3LCJleHAiOjMzMjc5Mjk1MzQ3fQ.WCIjTvKvnUY0PXPmT_R-T62WV9pyk3fyVWG4h-53P1I

# Scanner secret (server-side only — protects the cron trigger endpoint)
SCANNER_SECRET=generate_a_random_32_char_string


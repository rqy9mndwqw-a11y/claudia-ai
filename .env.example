# Groq API key (server-side only, never exposed to client)
GROQ_API_KEY=gsk_your_key_here

# CLAUDIA token contract on Base
NEXT_PUBLIC_CLAUDIA_CONTRACT=0x98eBd4Ac5d4f7022140c51e03CAc39d9F94CDE9B

# Minimum $CLAUDIA balance for access
NEXT_PUBLIC_MIN_CLAUDIA_BALANCE=10000

# WalletConnect project ID (free at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
